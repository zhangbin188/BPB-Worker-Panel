{
    "include": ["./src"], // 加了 ./ 修复路径错误
    "compilerOptions": {
        "target": "esnext",
        "module": "esnext",
        "types": ["@cloudflare/workers-types"],
        "moduleResolution": "bundler", // 替换废弃的 node
        "baseUrl": ".", // 必须改成 . 才能配合 paths 正常工作
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "paths": {
            "@xray/*": ["./src/cores/xray/*"],
            "@sing-box/*": ["./src/cores/sing-box/*"],
            "@clash/*": ["./src/cores/clash/*"],
            "@utils": ["./src/cores/utils"],
            "@handlers": ["./src/common/handlers"],
            "@init": ["./src/common/init"],
            "@common": ["./src/common/common"],
            "@vless": ["./src/protocols/websocket/vless"],
            "@trojan": ["./src/protocols/websocket/trojan"],
            "@warp": ["./src/protocols/warp"]
        }
    }
}
